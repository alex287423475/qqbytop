      "should_trigger_guardrail": [
        "WORD_COUNT_TOO_LOW",
        "OFF_TOPIC_RISK"
      ],
      "expected_engine_behavior": "Do not run normal paid deep critique first; flag word-count risk and off-topic/logical-break risk."
    }
  ]
