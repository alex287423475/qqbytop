{
  "dataset_name": "gaokao_duanwu_invitation_golden_v1",
  "prompt": "假设你是李华，请写邮件邀请外教 Mr. Smith 参加学校端午节文化活动。内容包括：活动时间地点、主要内容、邀请理由。",
  "cases": [
    {
      "filename": "student_01_type1.txt",
      "type": "type1_extremely_low_fragmented",
      "target_score_band": [0, 10],
      "expected_word_count_range": [100, 120],
      "expected_errors": ["fragmented_syntax", "spelling_errors", "logic_collapse", "chinese_pinyin_mixed"],
      "should_trigger_guardrail": [],
      "expected_engine_behavior": "Give a very low score, identify sentence-structure collapse and spelling breakdown, and do not infer missing logic beyond the text."
    },
    {
      "filename": "student_02_type2.txt",
      "type": "type2_chinglish_failing",
      "target_score_band": [11, 14],
      "expected_word_count_range": [100, 120],
      "expected_errors": ["chinglish", "literal_translation", "connector_overuse", "basic_sentence_errors"],
      "should_trigger_guardrail": [],
      "expected_engine_behavior": "Identify Chinglish and literal translation such as I very like, open our eyes, my heart will be very happy, and friendship more better."
    },
    {
      "filename": "student_03_type3.txt",
      "type": "type3_passing_complex_sentence_failures",
      "target_score_band": [15, 18],
      "expected_word_count_range": [100, 120],
      "expected_errors": ["there_be_verb_error", "although_but", "because_so", "relative_clause_error"],
      "should_trigger_guardrail": [],
      "expected_engine_behavior": "Return a passing but limited score, catch There are many students want, Although...but, Because...so, and unstable complex sentence attempts."
    },
    {
      "filename": "student_04_type4.txt",
      "type": "type4_good_plain_low_variety",
      "target_score_band": [19, 21],
      "expected_word_count_range": [100, 120],
      "expected_errors": ["plain_vocabulary", "simple_sentence_overuse", "low_expression_variety"],
      "should_trigger_guardrail": [],
      "expected_engine_behavior": "Do not over-penalize grammar; identify that the essay is correct but plain, and provide advanced restructuring suggestions."
    },
    {
      "filename": "student_05_edge_short_offtopic.txt",
      "type": "edge_short_offtopic",
      "target_score_band": null,
      "expected_word_count_range": [35, 45],
      "expected_errors": ["too_short", "off_topic", "logic_break"],
      "should_trigger_guardrail": ["WORD_COUNT_TOO_LOW", "OFF_TOPIC_RISK"],
      "expected_engine_behavior": "Do not run normal paid deep critique first; flag word-count risk and off-topic/logical-break risk."
    }
  ]
}
