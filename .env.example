# IELTS speaking tool frontend rewrite target.
# Local FastAPI default: http://127.0.0.1:8000
# Production target: https://ielts-api.qqbytop.com
IELTS_API_BASE_URL=http://127.0.0.1:8000

# Browser-visible API base used by client code.
NEXT_PUBLIC_IELTS_API_BASE=/tools/ielts-api

# Gaokao English essay diagnostic tool.
GAOKAO_ESSAY_BACKEND_API_BASE=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_GAOKAO_ESSAY_SINGLE_PRICE_CENTS=9900
NEXT_PUBLIC_GAOKAO_ESSAY_GROUP_PRICE_CENTS=5300
NEXT_PUBLIC_GAOKAO_ESSAY_PACK_CREDITS=20
NEXT_PUBLIC_GAOKAO_ESSAY_GROUP_REQUIRED_MEMBERS=3
NEXT_PUBLIC_GAOKAO_ESSAY_GROUP_EXPIRES_HOURS=24
NEXT_PUBLIC_GAOKAO_ESSAY_OFFICIAL_ASSIST_ENABLED=true
NEXT_PUBLIC_GAOKAO_ESSAY_FREE_LIMIT_PER_IP_HOUR=3
NEXT_PUBLIC_GAOKAO_ESSAY_FREE_GLOBAL_DAILY_LIMIT=3000
NEXT_PUBLIC_ENABLE_AD_PIXELS=false
NEXT_PUBLIC_GAOKAO_ESSAY_USE_BACKEND=false
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TOKEN=replace-with-long-random-token
GAOKAO_QUALITY_CONSOLE_ENABLED=false

# FastAPI backend settings. Change secrets in production.
ENVIRONMENT=development
DRAFT_TOKEN_SECRET=change-me-before-production
REPORT_AUTO_REFUND_AFTER_SECONDS=300
REPORT_MAX_RETRY_COUNT=2
OCR_PROVIDER=mock
LLM_PROVIDER_ORDER=mock_deepseek,mock_qwen,mock_doubao
STORAGE_PROVIDER=mock_presigned
PAYMENT_PROVIDER=mock
DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_CRITICAL_NAME=gaokao_essay_critical
QUEUE_DEFAULT_NAME=gaokao_essay_default
QUEUE_LOW_NAME=gaokao_essay_low
COS_BUCKET=
COS_REGION=ap-beijing
COS_SECRET_ID=
COS_SECRET_KEY=
ADMIN_API_TOKEN=
TENCENT_TOKENHUB_API_KEY=
TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_TOKENHUB_FREE_MODEL=deepseek-v4-flash
TENCENT_TOKENHUB_PAID_MODEL=deepseek-v4-pro
TENCENT_TOKENHUB_FALLBACK_MODEL=deepseek-v4-flash

# Production must set:
# ENVIRONMENT=production
# NEXT_PUBLIC_GAOKAO_ESSAY_USE_BACKEND=true
# DATABASE_URL=postgresql://...
# REDIS_URL=redis://...
# STORAGE_PROVIDER=cos
# OCR_PROVIDER=tencent_ocr
# LLM_PROVIDER_ORDER=tencent_tokenhub
# TENCENT_TOKENHUB_API_KEY=...
# TENCENT_TOKENHUB_FREE_MODEL=deepseek-v4-flash
# TENCENT_TOKENHUB_PAID_MODEL=deepseek-v4-pro
# TENCENT_TOKENHUB_FALLBACK_MODEL=deepseek-v4-flash
# PAYMENT_PROVIDER=wechat_alipay
