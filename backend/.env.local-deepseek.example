# Copy this file to backend/.env.local-deepseek and fill TENCENT_TOKENHUB_API_KEY.
# This file is for local real-LLM testing only. It keeps database, storage,
# OCR and payment mocked, but calls Tencent TokenHub DeepSeek for reports.

ENVIRONMENT=development
APP_NAME=gaokao-essay-backend-local-deepseek

DRAFT_TOKEN_SECRET=local-deepseek-change-me
DRAFT_TOKEN_TTL_SECONDS=900

REPOSITORY_PROVIDER=memory
DATABASE_URL=
REDIS_URL=

STORAGE_PROVIDER=mock_presigned
OCR_PROVIDER=mock
PAYMENT_PROVIDER=mock

LLM_PROVIDER_ORDER=tencent_tokenhub
TENCENT_TOKENHUB_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_TOKENHUB_API_KEY=replace-with-tokenhub-api-key
TENCENT_TOKENHUB_FREE_MODEL=deepseek-v4-flash
TENCENT_TOKENHUB_PAID_MODEL=deepseek-v4-pro
TENCENT_TOKENHUB_FALLBACK_MODEL=deepseek-v4-flash

CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

GAOKAO_ESSAY_SINGLE_PRICE_CENTS=9900
GAOKAO_ESSAY_GROUP_PRICE_CENTS=5300
GAOKAO_ESSAY_PACK_CREDITS=20
GAOKAO_ESSAY_GROUP_REQUIRED_MEMBERS=3
GAOKAO_ESSAY_GROUP_EXPIRES_HOURS=24

REPORT_AUTO_REFUND_AFTER_SECONDS=300
REPORT_MAX_RETRY_COUNT=2
FREE_DIAGNOSIS_RATE_LIMIT_PER_HOUR=3
UPLOAD_INTENT_RATE_LIMIT_PER_HOUR=5
SMART_APPEAL_RATE_LIMIT_PER_HOUR=5
SUPPORT_CHAT_RATE_LIMIT_PER_HOUR=20
SUPPORT_CHAT_LLM_ENABLED=false

